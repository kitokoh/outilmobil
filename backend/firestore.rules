rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Publicly readable collections (Keep existing ones, assuming they are needed)
    match /profileTemplates/{templateId} {
      allow read: if true;
      allow write: if false; // Admin-only writes
    }
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if false; // Admin-only writes
    }
    match /communityTemplates/{templateId} {
      allow read: if true;
      allow write: if false; // Admin-only writes
    }
    match /aiSuggestions/{suggestionId} {
      allow read: if true;
      allow write: if false; // Admin-only writes
    }

    // User's own document in 'users' collection
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId && request.resource.data.email == request.auth.token.email;
    }

    // Tasks collection: User can create, read, update, delete their own tasks.
    match /tasks/{taskId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Appointments collection: User can create, read, update, delete their own appointments.
    match /appointments/{appointmentId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Reminders collection (if it's distinct from Tasks and needed for Phase 1)
    match /reminders/{reminderId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }
  }
}
